# ============================================================
# INAYAT ROYALE — Root .gitignore
# Covers: Node.js, React/Vite frontend, PocketBase backend,
#         Windows OS files, IDE/editor files, secrets
# ============================================================


# ============================================================
# 🔐 SECRETS & ENVIRONMENT VARIABLES (never push these!)
# ============================================================
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging
*.env

# Specific env files inside web app
Apps/web/.env
Apps/web/.env.local
Apps/web/.env.development
Apps/web/.env.development.local
Apps/web/.env.production
Apps/web/.env.production.local


# ============================================================
# 📦 NODE.JS — Dependencies (very large, always reinstallable)
# ============================================================
node_modules/
Apps/web/node_modules/
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-store/


# ============================================================
# 🏗️ BUILD OUTPUTS (generated files, not source)
# ============================================================
# Root level dist
dist/

# Vite / React build output
Apps/web/dist/
Apps/web/build/
Apps/web/.vite/

# TypeScript compiled output
**/*.tsbuildinfo


# ============================================================
# 🗄️ POCKETBASE BACKEND
# ============================================================
# pb_data contains your DATABASE — include it if you want
# your data to be backed up, OR exclude it if it's too large
# or contains sensitive customer data.
#
# RECOMMENDATION: Exclude pb_data (customer data is private)
Apps/pocketbase/pb_data/

# PocketBase executable (32MB binary — too large for GitHub)
Apps/pocketbase/pocketbase.exe
Apps/pocketbase/pocketbase

# PocketBase logs
Apps/pocketbase/*.log
Apps/pocketbase/pb_data/logs/


# ============================================================
# 🧪 TEST & CACHE FILES
# ============================================================
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.tgz
.yarn-integrity


# ============================================================
# 📝 LOGS
# ============================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*


# ============================================================
# 🖥️ WINDOWS OS FILES (auto-generated by Windows Explorer)
# ============================================================
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
*.stackdump


# ============================================================
# 🍎 macOS FILES (in case collaborators use Mac)
# ============================================================
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes


# ============================================================
# 💻 IDE & EDITOR FILES
# ============================================================

# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json

# JetBrains (WebStorm, IntelliJ)
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
*.swp
*.swo
*~

# Sublime Text
*.sublime-project
*.sublime-workspace


# ============================================================
# 🔧 MISC
# ============================================================
# Temporary files
*.tmp
*.temp
*.bak
*.orig

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage reports
coverage/
*.lcov
.nyc_output/

# Compiled binary addons
build/Release/

# Optional package manager directories
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# Dockerfile is intentionally INCLUDED (needed by Railway)
# !Dockerfile
